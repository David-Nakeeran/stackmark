<%= form_with model: bookmark do |form|%>
  <% if form.object.errors.any?%>
    <p><%= form.object.errors.full_messages.first %></p>
  <%end%>
  <div>
    <%= form.label :url %>
    <%= form.text_field :url %>
    <%= form.label :title %>
    <%= form.text_field :title %>
    <%= form.label :description %>
    <%= form.text_field :description %>
    <%= form.label :notes %>
    <%= form.text_field :notes %>
  </div>
  <div>
    <%= form.submit %>
  </div>
<% end %>